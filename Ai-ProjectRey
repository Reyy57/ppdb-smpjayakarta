<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>AI ProjectRey</title>
    <script src="https://unpkg.com/@google/generative-ai@0.1.0/dist/index.min.js"></script>
    <style>
        body { font-family: sans-serif; max-width: 600px; margin: 20px auto; padding: 20px; }
        textarea, input { width: 100%; margin-bottom: 10px; padding: 10px; box-sizing: border-box; }
        button { padding: 10px 20px; background: #007bff; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>

    <h1>AI ProjectRey</h1>
    
    <input type="password" id="apiKeyInput" placeholder="Masukkan API Key lu di sini">
    
    <textarea id="prompt" rows="4" placeholder="Tanya sesuatu ke AI..."></textarea>
    
    <button onclick="runAI()">Kirim ke AI</button>
    
    <div id="output" style="margin-top: 20px; border: 1px solid #ccc; padding: 15px; min-height: 50px;">
        Hasil jawaban akan muncul di sini...
    </div>

    <script>
        async function runAI() {
            const apiKey = document.getElementById("apiKeyInput").value;
            const prompt = document.getElementById("prompt").value;
            const output = document.getElementById("output");
            
            if (!apiKey) {
                alert("Masukin API Key dulu ya!");
                return;
            }

            output.innerText = "Lagi mikir...";

            try {
                // Memanggil library Google Generative AI
                const { GoogleGenerativeAI } = window.google.generativeai;
                const genAI = new GoogleGenerativeAI(apiKey);
                const model = genAI.getGenerativeModel({ model: "gemini-pro" });

                const result = await model.generateContent(prompt);
                const response = await result.response;
                output.innerText = response.text();
            } catch (error) {
                output.innerText = "Error: " + error.message;
            }
        }
    </script>
</body>
</html>
